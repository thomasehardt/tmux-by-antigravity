#!/usr/bin/env bash
set -euo pipefail

INSTALL_DIR="$HOME/.local/share/tmux-mgr"

usage() {
    cat <<EOF
tmux-mgr - Manage your tmux-by-antigravity setup

Commands:
  install      Install config, backing up existing files
  update       Fetch latest config from GitHub and reload tmux
  edit         Open the tmux.conf in your \$EDITOR
  status       Check the status of your installation
  menu         Display the interactive tmux actions menu
  cheatsheet   Show the configuration cheatsheet
  ask <query>  Ask the Antigravity LLM a tmux-related question
EOF
}

backup_file() {
    local target="$1"
    local backup_dir="$2"
    if [ -e "$target" ] || [ -L "$target" ]; then
        local base
        base=$(basename "$target")
        echo "   Backing up $target to $backup_dir/$base"
        mv "$target" "$backup_dir/$base"
    fi
}

cmd_install() {
    echo "=> Installing tmux configuration..."
    local backup_dir="$HOME/.tmux-backup-$(date +%Y%m%d_%H%M%S)"
    
    # Check if existing .tmux.conf or .tmux/ is not already our symlink
    local need_backup=false
    if [ -e "$HOME/.tmux.conf" ] && [ "$(readlink "$HOME/.tmux.conf" || true)" != "$INSTALL_DIR/tmux.conf" ]; then
        need_backup=true
    fi
    if [ -e "$HOME/.tmux" ] && [ ! -d "$HOME/.tmux/scripts" ]; then
        need_backup=true
    fi

    if $need_backup; then
        echo "=> Found existing tmux config. Creating backup in $backup_dir"
        mkdir -p "$backup_dir"
        backup_file "$HOME/.tmux.conf" "$backup_dir"
        backup_file "$HOME/.tmux" "$backup_dir"
    fi

    echo "=> Setting up symlinks..."
    mkdir -p "$HOME/.tmux"
    ln -sf "$INSTALL_DIR/tmux.conf" "$HOME/.tmux.conf"
    
    # Using rm -rf and then ln -s is the most cross-platform way to update symlinked dirs
    rm -rf "$HOME/.tmux/scripts"
    ln -s "$INSTALL_DIR/scripts" "$HOME/.tmux/scripts"
    
    ln -sf "$INSTALL_DIR/cheatsheet.md" "$HOME/.tmux/cheatsheet.md"
    
    rm -rf "$HOME/.tmux/backup"
    ln -s "$INSTALL_DIR/backup" "$HOME/.tmux/backup"

    echo "=> Installing tmux plugin manager (TPM)..."
    if [ ! -d "$HOME/.tmux/plugins/tpm" ]; then
        git clone https://github.com/tmux-plugins/tpm "$HOME/.tmux/plugins/tpm"
    fi

    echo "=> Installing tmux plugins..."
    if [ -x "$HOME/.tmux/plugins/tpm/bin/install_plugins" ]; then
        "$HOME/.tmux/plugins/tpm/bin/install_plugins" || true
    fi

    echo "=> Installation complete!"
    
    # Create a local overrides file if it doesn't exist
    if [ ! -f "$HOME/.tmux.conf.local" ]; then
        echo "# Add your local tmux overrides here (e.g. changing the prefix key)" > "$HOME/.tmux.conf.local"
        echo "# This file will not be overwritten by tmux-mgr update." >> "$HOME/.tmux.conf.local"
    fi
    
    echo "=> You can now start tmux. Use 'tmux-mgr update' to pull future changes."
}

cmd_update() {
    echo "=> Updating tmux-mgr repository..."
    git -C "$INSTALL_DIR" pull
    
    # Run install again just to ensure symlinks are correct
    cmd_install "update"
    
    if command -v tmux >/dev/null 2>&1 && tmux info &> /dev/null; then
        echo "=> Reloading active tmux configuration..."
        tmux source-file "$HOME/.tmux.conf"
        echo "=> Reloaded."
    fi
}

cmd_edit() {
    local editor="${EDITOR:-nano}"
    if command -v vim >/dev/null 2>&1; then
        editor="${EDITOR:-vim}"
    fi
    "$editor" "$INSTALL_DIR/tmux.conf"
}

cmd_status() {
    echo "tmux-mgr installation status:"
    echo "  Install Dir: $INSTALL_DIR"
    if [ -d "$INSTALL_DIR" ]; then
        echo "  Current branch: $(git -C "$INSTALL_DIR" branch --show-current 2>/dev/null || echo 'unknown')"
        echo "  Latest commit: $(git -C "$INSTALL_DIR" log -1 --format="%h - %s" 2>/dev/null || echo 'unknown')"
    else
        echo "  Status: Not cloned yet."
    fi
    if [ "$(readlink "$HOME/.tmux.conf" || true)" == "$INSTALL_DIR/tmux.conf" ]; then
        echo "  Config Linked: Yes"
    else
        echo "  Config Linked: No (Run 'tmux-mgr install')"
    fi
}

cmd_menu() {
    if [ -z "${TMUX:-}" ]; then
        echo "Error: Must be inside a tmux session to display the popup menu."
        exit 1
    fi
    tmux display-menu -T "#[align=centre,fg=#89b4fa,bold] tmux actions " -x C -y C \
      "Help / Cheatsheet" "?" "display-popup -E -w 80% -h 80% \"$HOME/.tmux/scripts/cheatsheet.sh\"" \
      "" \
      "Scratch shell"   "\\" "display-popup -E -w 80% -h 75% -d \"#{pane_current_path}\" \"$HOME/.tmux/scripts/scratch.sh\"" \
      "Git overview"    "G"  "display-popup -E -w 90% -h 85% -d \"#{pane_current_path}\" \"$HOME/.tmux/scripts/git-overview.sh\"" \
      "Switch session"  "s"  "display-popup -E -w 50% -h 50% \"$HOME/.tmux/scripts/sessions.sh\"" \
      "Switch window"   "w"  "display-popup -E -w 70% -h 60% \"$HOME/.tmux/scripts/windows.sh\"" \
      "Open URL"        "u"  "display-popup -E -w 70% -h 60% \"$HOME/.tmux/scripts/url-open.sh #{pane_id}\"" \
      "Find project"    "f"  "display-popup -E -w 60% -h 60% \"$HOME/.tmux/scripts/sessionizer.sh\"" \
      "" \
      "Toggle sync"     "S"  "setw synchronize-panes" \
      "Toggle logging"  "P"  "pipe-pane -o \"cat >> \$HOME/.tmux/logs/#{session_name}-#{window_index}.log\"" \
      "Zoom pane"       "z"  "resize-pane -Z" \
      "" \
      "Save sessions"   "C-s" "run-shell \"$HOME/.tmux/scripts/save-sessions.sh\"" \
      "Restore sessions" "C-r" "run-shell \"$HOME/.tmux/scripts/restore-sessions.sh\"" \
      "Reload config"   "r"  "source-file ~/.tmux.conf" \
      "Cheatsheet"      "I"  "display-popup -E -w 80% -h 80% \"$HOME/.tmux/scripts/cheatsheet.sh\"" \
      "Kill pane"       "x"  "confirm-before -p \"kill pane #P? (y/n)\" kill-pane"
}

cmd_cheatsheet() {
    if [ -n "${TMUX:-}" ]; then
        tmux display-popup -E -w 80% -h 80% "$HOME/.tmux/scripts/cheatsheet.sh"
    else
        "$HOME/.tmux/scripts/cheatsheet.sh"
    fi
}

cmd_ask() {
    if [ $# -eq 0 ]; then
        echo "Usage: tmux-mgr ask <question>"
        exit 1
    fi
    local query="$*"
    if ! command -v agy >/dev/null 2>&1; then
        echo "Error: 'agy' (Antigravity CLI) is not installed or not in PATH."
        exit 1
    fi
    
    local prompt="Answer this question about tmux briefly and accurately: $query"
    
    if [ -n "${TMUX:-}" ]; then
        local tmp_script
        tmp_script=$(mktemp)
        chmod +x "$tmp_script"
        cat <<EOF > "$tmp_script"
#!/usr/bin/env bash
echo "🤖 Asking Antigravity..."
echo "────────────────────────────────────────"
agy -p "$prompt"
echo ""
echo "────────────────────────────────────────"
read -n 1 -s -r -p "Press any key to close..."
rm -f "$tmp_script"
EOF
        tmux display-popup -E -w 80% -h 80% "$tmp_script"
    else
        echo "🤖 Asking Antigravity..."
        agy -p "$prompt"
    fi
}

if [ $# -eq 0 ]; then
    usage
    exit 1
fi

case "$1" in
    install)    cmd_install ;;
    update)     cmd_update ;;
    edit)       cmd_edit ;;
    status)     cmd_status ;;
    menu)       cmd_menu ;;
    cheatsheet) cmd_cheatsheet ;;
    ask)        shift; cmd_ask "$@" ;;
    *)          usage; exit 1 ;;
esac
